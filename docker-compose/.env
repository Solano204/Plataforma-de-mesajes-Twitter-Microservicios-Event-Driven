COMPOSE_PATH_SEPARATOR=:
# zipkin.yml is required: kafka-streams-service depends_on zipkin. monitoring.yml
# (grafana/prometheus) is optional observability tooling, included for consistency.
# postgres.yml is required: keycloak-authorization-server, elastic-query-service,
# and analytics-service all use the containerized "postgres" service now (no host
# port published - see postgres.yml) instead of a native Postgres on the host, so
# this stack is fully self-contained and doesn't depend on anything already
# installed/running on the machine it's brought up on.
COMPOSE_FILE=common.yml:kafka_cluster.yml:elastic_cluster.yml:redis_cluster.yml:postgres.yml:monitoring.yml:zipkin.yml:services.yml
KAFKA_VERSION=7.3.0
ELASTIC_VERSION=7.17.4
KEYCLOAK_VERSION=15.0.1
REDIS_VERSION=6.0.5
GRAFANA_VERSION=5.4.3
PROMETHEUS_VERSION=v2.19.2
ZIPKIN_VERSION=2.22.2
SERVICE_VERSION=0.0.1-SNAPSHOT
GLOBAL_NETWORK=application
GROUP_ID=com.microservices.demo
ENCRYPT_KEY=your-encryption-key-here
TWITTER_BEARER_TOKEN=your-twitter-bearer-token-here



# Local Environment Variables for Development
# Copy this to .env.local for local development

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8187
SERVER_SERVLET_CONTEXT_PATH=/

# Spring Cloud Config
SPRING_CLOUD_CONFIG_URI=http://localhost:8888

# OAuth2 Security (Local Keycloak)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:9091/auth/realms/microservices-realm
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://localhost:9091/auth/realms/microservices-realm/protocol/openid-connect/certs

# Kafka Configuration (Local)
KAFKA_CONFIG_BOOTSTRAP_SERVERS=localhost:19092,localhost:29092,localhost:39092
KAFKA_CONFIG_SCHEMA_REGISTRY_URL=http://localhost:8081
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka Streams
# Doc 4/resilience-hygiene: this used to be ${HOME}/kafka-streaming-state, but
# .env files are parsed literally (no shell expansion) by docker-compose,
# IDE run configs, and most dotenv-style loaders - only an actual `source`'d
# bash script expands ${HOME}. Every other consumer of this file created a
# real, literal directory named "${HOME}" instead of resolving it, which is
# exactly what happened in this checkout (see the cleanup in this same pass).
# A relative path is the portable choice here since this file's own header
# says it's for local (non-Docker) dev.
KAFKA_STREAMS_STATE_FILE_LOCATION=./kafka-streaming-state

# Eureka Discovery (Local)
EUREKA_CLIENT_SERVICE_URL_DEFAULT_ZONE=http://localhost:8761/eureka/

# Zipkin and Tracing (Local)
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://localhost:9411/api/v2/spans
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0

# Logging Levels (More verbose for local development)
LOGGING_LEVEL_COM_MICROSERVICES_DEMO=DEBUG
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_KAFKA=DEBUG
LOGGING_LEVEL_TRACING=DEBUG
LOGGING_LEVEL_ZIPKIN=DEBUG
LOGGING_LEVEL_BRAVE=DEBUG



SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8187
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BROKERS=localhost:19092,localhost:29092,localhost:39092
SCHEMA_REGISTRY_URL=http://localhost:8081
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
JWT_ISSUER_URI=http://localhost:9091/auth/realms/microservices-realm
JWT_JWK_SET_URI=http://localhost:9091/auth/realms/microservices-realm/protocol/openid-connect/certs
KAFKA_LOG_LEVEL=DEBUG
TRACING_LOG_LEVEL=DEBUG
ZIPKIN_LOG_LEVEL=DEBUG
BRAVE_LOG_LEVEL=DEBUG


SPRING_PROFILES_ACTIVE=dev
 CONFIG_SERVER_URL=http://localhost:8888
 KAFKA_BOOTSTRAP_SERVERS=localhost:9092
 ZIPKIN_URL=http://localhost:9411
 TRACING_PROBABILITY=1.0
EUREKA_URL=http://localhost:8761/eureka/
 KEYCLOAK_URL=http://localhost:9091
 KEYCLOAK_REALM=microservices-realm