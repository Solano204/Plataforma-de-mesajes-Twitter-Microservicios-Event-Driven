        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="kafka-streams-service /actuator/health" enabled="true">
          <stringProp name="HTTPSampler.port">8187</stringProp>
          <stringProp name="HTTPSampler.path">/actuator/health</stringProp>
