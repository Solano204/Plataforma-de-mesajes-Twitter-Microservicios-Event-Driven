        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="analytics-service /actuator/health" enabled="true">
          <stringProp name="HTTPSampler.port">8188</stringProp>
          <stringProp name="HTTPSampler.path">/actuator/health</stringProp>
